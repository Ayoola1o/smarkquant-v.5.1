<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Compact square logo for favicon -->
  <rect width="200" height="200" fill="#1e3a8a"/>
  <defs>
    <linearGradient id="fav" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#60a5fa" />
      <stop offset="100%" style="stop-color:#fbbf24" />
    </linearGradient>
  </defs>
  <text x="100" y="145" font-family="Arial, sans-serif" font-size="110" font-weight="bold" fill="url(#fav)" text-anchor="middle">SM</text>
</svg>