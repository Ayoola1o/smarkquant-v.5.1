# Alpaca Trading API
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Database path — set to /data/market_data.db on Railway/Render (persistent disk)
# Leave blank to use the local default (backend/market_data.db)
DB_PATH=

# CORS — comma-separated list of allowed frontend origins in production
# e.g. https://smarkquant.vercel.app,https://smarkquant.onrender.com
ALLOWED_ORIGINS=*
